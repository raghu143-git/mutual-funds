def k_way_merge(arrays, buffer_size=3):
    k = 5
    index = [0] * k          # current index in each array
    buffers = [[] for _ in range(k)]
    result = []

    # function to refill buffer
    def fill_buffer(i):
        start = index[i]
        end = min(start + buffer_size, len(arrays[i]))
        buffers[i] = arrays[i][start:end]
        index[i] = end

    # initial buffer fill
    for i in range(k):
        fill_buffer(i)

    while True:
        min_val = float('inf')
        min_i = -1

        # find smallest element among buffers
        for i in range(k):
            if buffers[i] and buffers[i][0] < min_val:
                min_val = buffers[i][0]
                min_i = i

        # stop when all buffers are empty
        if min_i == -1:
            break

        # add smallest element to result
        result.append(min_val)
        buffers[min_i].pop(0)

        # refill buffer if empty
        if not buffers[min_i] and index[min_i] < len(arrays[min_i]):
            fill_buffer(min_i)

    return result
